        </mxCell>

        <mxCell id="open_translate" value="&lt;b&gt;Open-set translation&lt;/b&gt;&lt;br&gt;parameter, studyGroups, age, dose, duration become API constraints." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#D27A18;fontColor=#4C2F0F;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="640" y="620" width="250" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="full_count" value="&lt;b&gt;Aggregate full query and count&lt;/b&gt;&lt;br&gt;Closed-set and open-set API filters." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF6DB;strokeColor=#BE8A00;fontColor=#493808;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="960" y="620" width="240" height="100" as="geometry"/>
        </mxCell>
        <mxCell id="final_api" value="&lt;b&gt;Final API count&lt;/b&gt;&lt;br&gt;Use data.countTotal." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF4EE;strokeColor=#4B8B5B;fontColor=#1F3D2A;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1260" y="620" width="210" height="85" as="geometry"/>
        </mxCell>

        <mxCell id="closed_sets" value="&lt;b&gt;Field inputs&lt;/b&gt;&lt;br&gt;Small closed &amp;lt;1000, closed &amp;ge;1000, enums, booleans, invariants, open fields." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FBF9;strokeColor=#23856D;fontColor=#214338;align=left;verticalAlign=top;spacing=12;fontSize=13;arcSize=8;" vertex="1" parent="1">
