        </mxCell>
        <mxCell id="final_rows_early" value="&lt;b&gt;Final row count&lt;/b&gt;&lt;br&gt;Filtered datapoints." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF4EE;strokeColor=#4B8B5B;fontColor=#1F3D2A;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
