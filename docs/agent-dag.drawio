<mxfile host="app.diagrams.net">
  <diagram id="oppp-count-gated-pipeline" name="OPPP Count-Gated Pipeline">
    <mxGraphModel dx="1700" dy="1000" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1200" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <mxCell id="title" value="&lt;b&gt;PharmaPendium PK Count-Gated Translation&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=28;fontColor=#17202A;" vertex="1" parent="1">
          <mxGeometry x="60" y="40" width="900" height="40" as="geometry"/>
        </mxCell>
        <mxCell id="subtitle" value="Expansion, decomposition, TERMite enrichment, staged translation, API count gates, row filtering, and final count." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=14;fontColor=#52616B;" vertex="1" parent="1">
          <mxGeometry x="60" y="82" width="1250" height="32" as="geometry"/>
        </mxCell>

        <mxCell id="input" value="&lt;b&gt;Natural-language question&lt;/b&gt;&lt;br&gt;User wording, filters, entities, and output intent." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#37474F;fontColor=#17202A;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="160" width="200" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="expand" value="&lt;b&gt;Query expansion&lt;/b&gt;&lt;br&gt;Clarify abbreviations while preserving meaning." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF2FF;strokeColor=#2F6FDB;fontColor=#17324D;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="310" y="160" width="200" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="decompose" value="&lt;b&gt;Query decomposition&lt;/b&gt;&lt;br&gt;One component per field with nl_fragment, type, and reason." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2EEFF;strokeColor=#6B4FD3;fontColor=#2E245F;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="560" y="160" width="200" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="termite" value="&lt;b&gt;TERMite enrichment&lt;/b&gt;&lt;br&gt;Run on each nl_fragment in its selected field context." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF7F7;strokeColor=#168B8B;fontColor=#123A3A;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="810" y="160" width="220" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="early_translate" value="&lt;b&gt;Small closed / early translation&lt;/b&gt;&lt;br&gt;Ground closed fields with &amp;lt;1000 values." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F6F1;strokeColor=#23856D;fontColor=#12342D;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1080" y="160" width="220" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="early_count" value="&lt;b&gt;Aggregate and count&lt;/b&gt;&lt;br&gt;Early filters plus PK invariants." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF6DB;strokeColor=#BE8A00;fontColor=#493808;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1350" y="160" width="210" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="gate1" value="&lt;b&gt;countTotal &amp;lt; 1000?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFDF4;strokeColor=#BE8A00;fontColor=#493808;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="1610" y="152" width="140" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="fetch_early" value="&lt;b&gt;Fetch datapoints&lt;/b&gt;&lt;br&gt;Use early API query." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF2F4;strokeColor=#60717C;fontColor=#25333A;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1480" y="350" width="210" height="90" as="geometry"/>
        </mxCell>
        <mxCell id="filter_all" value="&lt;b&gt;Apply remaining filters&lt;/b&gt;&lt;br&gt;Closed, enum, boolean, invariant, and open row filters." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF4EE;strokeColor=#4B8B5B;fontColor=#1F3D2A;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
