        </mxCell>
        <mxCell id="filter_open" value="&lt;b&gt;Apply open-set filters&lt;/b&gt;&lt;br&gt;Filter fetched datapoints locally." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF4EE;strokeColor=#4B8B5B;fontColor=#1F3D2A;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
