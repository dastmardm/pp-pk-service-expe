<mxfile host="65bd71144e">
    <diagram id="agent-dag" name="Agent DAG">
        <mxGraphModel dx="2071" dy="1195" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1900" pageHeight="1250" math="0" shadow="0">
            <root>
                <mxCell id="0"/>
                <mxCell id="1" parent="0"/>
                <mxCell id="title" value="&lt;b&gt;PharmaPendium NL -&gt; Machine-Query Agent&lt;/b&gt;" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=28;fontColor=#17202A;" parent="1" vertex="1">
                    <mxGeometry x="55" y="30" width="900" height="42" as="geometry"/>
                </mxCell>
                <mxCell id="subtitle" value="Enhance, decompose, ground closed-set fields, emit open-set constraints directly, then aggregate and execute countTotal." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=15;fontColor=#52616B;" parent="1" vertex="1">
                    <mxGeometry x="57" y="72" width="1120" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="input" value="&lt;b&gt;Natural-language query&lt;/b&gt;&lt;br&gt;User question, filters, entities, and output intent." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#36454F;fontColor=#17202A;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="60" y="130" width="300" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="expand" value="&lt;b&gt;Stage -1 - Expand&lt;/b&gt;&lt;br&gt;Clarify abbreviations; preserve meaning." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E9F2FF;strokeColor=#2F6FDB;fontColor=#17324D;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="60" y="270" width="300" height="105" as="geometry"/>
                </mxCell>
        <mxCell id="enhance" value="&lt;b&gt;Stage 0 - Enhance&lt;/b&gt;&lt;br&gt;Required TERMite labels, types, and synonyms." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF7F7;strokeColor=#168B8B;fontColor=#123A3A;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="60" y="410" width="300" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="decompose" value="&lt;b&gt;Stage 1 - Decompose&lt;/b&gt;&lt;br&gt;One field per component. No value selection." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F2EEFF;strokeColor=#6B4FD3;fontColor=#2E245F;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="60" y="550" width="300" height="120" as="geometry"/>
                </mxCell>
                <mxCell id="open_set" value="&lt;b&gt;Open-set direct filters&lt;/b&gt;&lt;br&gt;parameter, parameterDisplay, studyGroups, age, dose, duration.&lt;br&gt;&lt;br&gt;No complete local taxonomy; emit MATCH or REGEX directly and use optional zero-count probes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF4E6;strokeColor=#D27A18;fontColor=#4C2F0F;align=left;verticalAlign=top;spacing=12;fontSize=13;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="60" y="760" width="300" height="205" as="geometry"/>
                </mxCell>
                <mxCell id="closedsets" value="&lt;b&gt;Input closed sets&lt;/b&gt;&lt;br&gt;inputs/*.csv, inline enums, booleans" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F8FBF9;strokeColor=#23856D;fontColor=#214338;align=left;verticalAlign=top;spacing=10;fontSize=13;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="440" y="155" width="450" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="config" value="&lt;b&gt;Service config&lt;/b&gt;&lt;br&gt;field buckets, entity routes, facets, invariants" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFFDF4;strokeColor=#BE8A00;fontColor=#493808;align=left;verticalAlign=top;spacing=10;fontSize=13;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="950" y="155" width="430" height="75" as="geometry"/>
                </mxCell>
                <mxCell id="stage2a" value="&lt;b&gt;Stage 2 - Per-field translation&lt;/b&gt;&lt;br&gt;Ground closed-set fields and emit open-set fields directly.&lt;br&gt;&lt;br&gt;pool + closed_set&lt;br&gt;exact -&gt; fuzzy -&gt; LLM pool enrichment&lt;br&gt;-&gt; exact/fuzzy retry -&gt; closed-set LLM selection&lt;br&gt;&lt;br&gt;Closed-set selections must be in closed_set. Open-set filters emit direct MATCH or REGEX constraints." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F6F1;strokeColor=#23856D;fontColor=#12342D;align=left;verticalAlign=top;spacing=14;fontSize=14;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="440" y="270" width="450" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="stage3a" value="&lt;b&gt;Stage 3 - Aggregate&lt;/b&gt;&lt;br&gt;Keep valid filters and build the API-layer query.&lt;br&gt;&lt;br&gt;Assemble boolean tree, entityFilters, facets/displayColumns, service invariants, validation, and optional open-set probes." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF6DB;strokeColor=#BE8A00;fontColor=#493808;align=left;verticalAlign=top;spacing=14;fontSize=14;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="950" y="270" width="430" height="280" as="geometry"/>
                </mxCell>
        <mxCell id="api" value="&lt;b&gt;API count execution&lt;/b&gt;&lt;br&gt;Execute the validated machine query.&lt;br&gt;&lt;br&gt;Read data.countTotal; full datapoint rows are not retrieved.&lt;br&gt;&lt;br&gt;Open-set probes use isolated count requests." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF2F4;strokeColor=#60717C;fontColor=#25333A;align=left;verticalAlign=top;spacing=14;fontSize=14;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="1440" y="270" width="390" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="probe_inputs" value="&lt;b&gt;Open-set probe inputs&lt;/b&gt;&lt;br&gt;Each emitted open-set filter can be counted in isolation before final aggregation." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3F0FF;strokeColor=#7456D8;fontColor=#2E245F;align=left;verticalAlign=top;spacing=14;fontSize=14;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="1440" y="660" width="390" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="stage2b" value="&lt;b&gt;Probe handling&lt;/b&gt;&lt;br&gt;A confirmed zero-count open-set probe drops that filter and records a warning.&lt;br&gt;&lt;br&gt;Probe errors keep the filter." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F5EDFF;strokeColor=#9256C9;fontColor=#3F2457;align=left;verticalAlign=top;spacing=14;fontSize=14;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="950" y="660" width="430" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="stage3b" value="&lt;b&gt;Auditable filter layers&lt;/b&gt;&lt;br&gt;The output records closed-set filters, open-set filters, service invariants, output options, probe warnings, and execution metadata." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEFEA;strokeColor=#C85F42;fontColor=#563025;align=left;verticalAlign=top;spacing=14;fontSize=14;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="440" y="660" width="450" height="280" as="geometry"/>
                </mxCell>
                <mxCell id="final" value="&lt;b&gt;Final result surface&lt;/b&gt;&lt;br&gt;Machine-query payload, selected facets/display columns, invalid-translation warnings, probe warnings, countTotal execution metadata, and grounding audit trail." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EAF4EE;strokeColor=#4B8B5B;fontColor=#1F3D2A;align=left;verticalAlign=top;spacing=14;fontSize=15;arcSize=8;" parent="1" vertex="1">
                    <mxGeometry x="440" y="1015" width="1390" height="105" as="geometry"/>
                </mxCell>
                <mxCell id="legend" value="Solid arrows: runtime data flow. Dashed arrows: helper inputs or probe flows. Closed-set translation never emits values outside the active closed set." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;fontSize=13;fontColor=#52616B;" parent="1" vertex="1">
