        </mxCell>

        <mxCell id="closed_translate" value="&lt;b&gt;Closed translation&lt;/b&gt;&lt;br&gt;Ground closed fields with at least 1000 values." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E8F6F1;strokeColor=#23856D;fontColor=#12342D;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="1120" y="350" width="230" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="closed_count" value="&lt;b&gt;Aggregate and count&lt;/b&gt;&lt;br&gt;Small closed plus closed filters." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF6DB;strokeColor=#BE8A00;fontColor=#493808;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="850" y="350" width="220" height="95" as="geometry"/>
        </mxCell>
        <mxCell id="gate2" value="&lt;b&gt;countTotal &amp;lt; 1000?&lt;/b&gt;" style="rhombus;whiteSpace=wrap;html=1;fillColor=#FFFDF4;strokeColor=#BE8A00;fontColor=#493808;align=center;verticalAlign=middle;fontSize=14;" vertex="1" parent="1">
          <mxGeometry x="640" y="342" width="140" height="110" as="geometry"/>
        </mxCell>

        <mxCell id="fetch_closed" value="&lt;b&gt;Fetch datapoints&lt;/b&gt;&lt;br&gt;Use closed-set API query." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EEF2F4;strokeColor=#60717C;fontColor=#25333A;align=left;verticalAlign=top;spacing=12;fontSize=14;arcSize=8;" vertex="1" parent="1">
