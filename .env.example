# oppp environment template — copy to `.env` and fill in real values.
# `.env` is never committed (see specs/git.md → Never Commit). The deterministic
# core needs none of these; they are read lazily, only when a model/entity
# backend is actually invoked (config.py → get_settings / load_dotenv_if_present).

# --- Inputs ---
# Override the default `inputs/` directory (controlled-vocabulary tables + gold set).
OPPP_INPUTS_DIR=

# --- Model provider (Portkey) — only read when a model-backed backend runs ---
PORTKEY_ENDPOINT=
PORTKEY_API_KEY=
PORTKEY_PROVIDER=
TOOL_MODEL=

# --- Entity recognition (SciBite TERMite) — only for the 'termite' enhancer ---
TERMITE_HOME=
TERMITE_AUTH_URL=
TERMITE_CLIENT_NAME=
TERMITE_CLIENT_SECRET=
