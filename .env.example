# oppp environment template — copy to `.env` and fill in real values.
# `.env` is never committed. The deterministic core needs none of these;
# they are read lazily only when the stage that needs them is invoked.

# --- Inputs (optional) ---
OPPP_INPUTS_DIR=

# --- Model provider (Portkey) — required for LLM-backed stages ---
PORTKEY_ENDPOINT=
PORTKEY_API_KEY=
PORTKEY_PROVIDER=
TOOL_MODEL=
LLM_SEED=

# --- Entity recognition (SciBite TERMite) — required for Stage 0 ---
TERMITE_HOME=
TERMITE_AUTH_URL=
TERMITE_CLIENT_NAME=
TERMITE_CLIENT_SECRET=
